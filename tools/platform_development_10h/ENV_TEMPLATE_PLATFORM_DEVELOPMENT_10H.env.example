# Platform Development 10H — Actual Negative UAT Evidence Runner Environment
# Copy to a local, ignored file and fill real staging actors. Do not commit secrets.

PWF_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PWF_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Required target identifiers. Use non-production/staging targets only.
PWF_NEGATIVE_UAT_TARGET_ADMIN_USER_ID=00000000-0000-0000-0000-000000000000
PWF_NEGATIVE_UAT_SUPERUSER_SELF_USER_ID=00000000-0000-0000-0000-000000000000
PWF_NEGATIVE_UAT_SYSTEM_KEY=platformAdmin
PWF_NEGATIVE_UAT_OUT_OF_SCOPE_SYSTEM_KEY=platformAdmin
PWF_NEGATIVE_UAT_ROLE_KEY=platform_admin
PWF_NEGATIVE_UAT_PERMISSION_KEY=manage_users

# Actor credentials. Use staging users prepared specifically for negative UAT.
PWF_UAT_UNAUTHORIZED_EMAIL=unauthorized@example.test
PWF_UAT_UNAUTHORIZED_PASSWORD=CHANGE_ME
PWF_UAT_SCOPED_EMAIL=scoped@example.test
PWF_UAT_SCOPED_PASSWORD=CHANGE_ME
PWF_UAT_UNIT_ADMIN_EMAIL=unit-admin@example.test
PWF_UAT_UNIT_ADMIN_PASSWORD=CHANGE_ME
PWF_UAT_PLATFORM_ADMIN_EMAIL=platform-admin@example.test
PWF_UAT_PLATFORM_ADMIN_PASSWORD=CHANGE_ME
PWF_UAT_SUPERUSER_EMAIL=superuser@example.test
PWF_UAT_SUPERUSER_PASSWORD=CHANGE_ME

# Optional output folder.
PWF_NEGATIVE_UAT_OUTPUT_DIR=evidence/platform_development_10h_actual_negative_uat/results
