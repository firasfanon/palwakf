SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# dry أو apply
SEED_MODE=dry

# false لإنشاء كل الوحدات الفعالة, أو true لاختبار وحدة/وحدات محددة
ONLY_SELECTED=false
SELECTED_LOGIN_KEYS=bth,ram,tub

# صيغة البريد التجريبي
EMAIL_DOMAIN=palwakf.local

# أنماط التعبئة داخل admin_users
DEPARTMENT_MODE=slug
NAME_MODE=username

# استخدم true إذا أردت تأكيد البريد تلقائيًا للحسابات التجريبية
EMAIL_CONFIRM=true

USER_ROLE=employee

# Document Intelligence — engine adapter mode
# local_review: deterministic local review fallback, does not claim production OCR/CAD.
# supabase_rpc: calls public RPC wrapper connected to a real engine/Edge Function/service.
PWF_DOCUMENT_ENGINE_MODE=local_review
PWF_DOCUMENT_ENGINE_RPC_NAME=rpc_document_engine_process_v1
